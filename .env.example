# Backend Environment Variables
# Copy this file to .env.local and fill in your actual values

PORT=5000

# MongoDB Connection String
# Use a direct connection string if SRV DNS resolution is blocked.
# Example with Atlas shard hosts:
# mongodb://username:password@ac-xxxx-shard-00-00.mongodb.net:27017,ac-xxxx-shard-00-01.mongodb.net:27017,ac-xxxx-shard-00-02.mongodb.net:27017/?ssl=true&replicaSet=atlas-xxxxxx-shard-0&authSource=admin&appName=YourAppName
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/petAdoption?retryWrites=true&w=majority

# Node Environment
NODE_ENV=development
